\begin{frame}{\fttheory{The Arbitrage Pricing Theory}}
	\begin{itemize}
		\item These examples show that if $\alpha\neq0$, then one can costlessly construct a portfolio that pays $|\alpha|$ on average. 
		\item Suppose, for concreteness, that $\alpha>0$ (as in the Walmart example). Then arbitrageurs start buying the stock. According to the laws of supply and demand, the price will rise (the return will fall) until $\alpha=0$.
		\item The APT claims that $\alpha=0$ on average:
			\begin{equation}
				\text{E}[r_{S}-r_{F}]=\beta\text{E}[r_{M}-r_{F}]
			\end{equation}
			which is exactly what the CAPM claims. 
		\item The APT tells us \textit{why} the CAPM should hold and \textit{how} to profit when it breaks.
	\end{itemize}
\end{frame}

\begin{frame}{\ftdata{Application: Fama-French}}
	\begin{equation}
		r_{S}-r_{F}=\alpha+\beta_{\text{MKT}}(r_{\text{MKT}}-r_{F})+\beta_{\text{SMB}}r_{\text{SMB}}+\beta_{\text{HML}}r_{\text{HML}}+\epsilon
	\end{equation}
	\begin{itemize}
		\item $r_{\text{SMB}}$ is the return on a portfolio that goes long the (S)mallest 10\% of stocks (by market cap) and goes short the (B)iggest 10\% of stocks
		\item $r_{\text{HML}}$ is the return on a portfolio that goes long the stocks with the (H)ighest 10\% of stocks (by market cap) and goes short the (L)owest 10\% of stocks
	\end{itemize}
\end{frame}

